<UserControl
    x:Class="OF.FSimMan.View.Game.Fs.FsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cmp="clr-namespace:CLS.Core.Wpf.Component;assembly=CLS.Core.Wpf"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:OF.FSimMan.ViewModel.Game.Fs;assembly=OF.FSimMan.ViewModels"
    d:DataContext="{d:DesignInstance Type={x:Type vm:FsViewModelBase}}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <cmp:BusyIndicator BusyContent="{Binding Client.BusyContent, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsBusy="{Binding Client.IsBusy, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <cmp:Heading
                Grid.Row="0"
                HorizontalAlignment="Left"
                Text="Modpacks" />
            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <cmp:ImageButton
                    Margin="0"
                    VerticalAlignment="Bottom"
                    Command="{Binding RefreshModPacksCommand}"
                    Content="Refresh"
                    ImageSource="{StaticResource RefreshIcon}" />
                <cmp:ImageButton
                    Margin="5,0,0,0"
                    VerticalAlignment="Bottom"
                    Command="{Binding NewModPackCommand}"
                    Content="Create new"
                    ImageSource="{StaticResource PlusIcon}"
                    Visibility="{Binding AppSettings.IsApplicationModeCreator, Converter={StaticResource BooleanVisibilityConverter}}" />
                <cmp:ImageButton
                    Margin="5,0,0,0"
                    VerticalAlignment="Bottom"
                    Command="{Binding ImportModPackCommand}"
                    Content="Import"
                    ImageSource="{StaticResource FileImportIcon}"
                    Visibility="{Binding IsModPackImportVisible, Converter={StaticResource BooleanVisibilityConverter}}" />
                <cmp:ImageButton
                    Margin="5,0,0,0"
                    VerticalAlignment="Bottom"
                    Content="Get from Hub"
                    ImageSource="{StaticResource DownloadIcon}"
                    Visibility="{Binding IsModPackHubVisible, Converter={StaticResource BooleanVisibilityConverter}}" />
            </StackPanel>

            <DataGrid
                Grid.Row="2"
                Margin="0,5,0,0"
                VerticalAlignment="Stretch"
                ItemsSource="{Binding Client.ModPacks.List, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                Style="{StaticResource ModpacksDataGridStyle}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn
                        MinWidth="150"
                        CellTemplate="{StaticResource ModpacksDataGridModpackDataTemplate}"
                        Header="Modpack"
                        HeaderStyle="{StaticResource DataGridColumnHeaderLeftStyle}" />
                    <DataGridTemplateColumn
                        Width="*"
                        CellTemplate="{StaticResource ModpacksDataGridDescriptionDataTemplate}"
                        Header="Description"
                        HeaderStyle="{StaticResource DataGridColumnHeaderLeftStyle}" />
                    <DataGridTemplateColumn MinWidth="150" CellTemplate="{StaticResource ModpacksDataGridControlsDataTemplate}" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </cmp:BusyIndicator>
</UserControl>
